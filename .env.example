# Oura API OAuth credentials (https://cloud.ouraring.com/console)
OURA_CLIENT_ID=your_oura_client_id
OURA_CLIENT_SECRET=your_oura_client_secret
PORT=3000

# Public URL of this server — used for OAuth redirect URIs.
# When running behind a Cloudflare Tunnel, set this to your public tunnel URL.
# Example: https://oura.example.com
SERVER_URL=https://oura.example.com

# Cloudflare Tunnel token (https://one.dash.cloudflare.com/ -> Networks -> Tunnels)
# Create a tunnel and configure it to route traffic to http://oura-mcp:3000
CLOUDFLARE_TUNNEL_TOKEN=your_cloudflare_tunnel_token
